{
  "name": "x-agent",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "x-agent": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc && printf '#!/usr/bin/env node\\n' | cat - dist/main.js > dist/main.tmp && mv dist/main.tmp dist/main.js && chmod +x dist/main.js",
    "start": "tsx main.tsx",
    "test": "vitest run main.test.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.86.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
